{
  "name": "learn-claude-code",
  "version": "0.0.1",
  "main": "dist/agent.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/agent.js",
    "start:anthropic": "npm run build && MODEL_PROVIDER=anthropic node dist/agent.js",
    "start:openai": "npm run build && MODEL_PROVIDER=openai node dist/agent.js",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "openai": "^4.52.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  }
}
